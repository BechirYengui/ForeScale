{
  "title": "ForeScale -- predictive autoscaling",
  "uid": "forescale",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[30s]))",
          "legendFormat": "observed rps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "inference-api replicas (warm pods)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "count(inference_capacity_rps)",
          "legendFormat": "ready pods",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency percentiles (ms)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLA 500ms" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 6], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.50, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "expr": "vector(500)",
          "legendFormat": "SLA 500ms",
          "refId": "D"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "In-flight requests (queue pressure)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(inference_inflight_requests)",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ]
    }
  ]
}
